# Copy this to .env on Nibbler and adjust only if needed.

TZ=Europe/London

# Host paths on Nibbler
LORA_BUILDER_ROOT=/home/clink/docker/lora_builder
LORA_BUILDER_DATA=/home/clink/docker/lora_builder/data
LORA_BUILDER_LORAS=/home/clink/docker/lora_builder/mounts/loras

# Paths visible inside containers
LORA_ROOT=/loras
LORA_DB_PATH=/data/lora_master.db

# Direct LAN test port before NPM proxying
LORA_BUILDER_HTTP_PORT=5174
